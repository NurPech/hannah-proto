{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "mergeConfidence:all-badges"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "packageRules": [
    {
      "matchDepTypes": [
        "dependencies"
      ],
      "commitMessagePrefix": "feat(deps):"
    },
    {
      "matchDepTypes": [
        "devDependencies"
      ],
      "commitMessagePrefix": "chore(dev-deps):"
    }
  ]
}
